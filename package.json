{
  "name": "resuturant-pos-system",
  "version": "1.4.9",
  "preview": false,
  "description": "Restaurant POS desktop shell",
  "main": "./out/main/index.js",
  "author": "achiraGaming",
  "homepage": "https://www.electronjs.org",
  "build": {
    "appId": "com.achiraGaming.resuturant-pos-system",
    "productName": "Restaurant POS System",
    "directories": {
      "buildResources": "build"
    },
    "asar": true,
    "files": [
      "**/*",
      "!**/.vscode/*",
      "!src/*",
      "!electron.vite.config.{js,ts,mjs,cjs}",
      "!{eslint.config.mjs,.prettierignore,.prettierrc.yaml,dev-app-update.yml,CHANGELOG.md,README.md}",
      "!{.env,.env.*,.npmrc,pnpm-lock.yaml}",
      "build/**/*"
    ],
    "asarUnpack": [
      "resources/**",
      "build/**"
    ],
    "win": {
      "icon": "build/windows/icons/icon.ico",
      "target": "nsis"
    },
    "nsis": {
      "installerIcon": "build/windows/icons/icon.ico",
      "uninstallerIcon": "build/windows/icons/icon.ico",
      "installerHeaderIcon": "build/windows/icons/icon.ico",
      "artifactName": "${name}-${version}-setup.${ext}",
      "uninstallDisplayName": "${productName} Uninstaller",
      "createDesktopShortcut": "always",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "differentialPackage": true
    },
    "publish": []
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "electron-vite preview",
    "dev": "electron-vite dev --watch",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:win": "npm run build && electron-builder --win ",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux "
  },
  "dependencies": {
    "@ant-design/icons": "^5.2.6",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fortawesome/fontawesome-svg-core": "^6.4.2",
    "@fortawesome/free-regular-svg-icons": "^6.4.2",
    "@fortawesome/free-solid-svg-icons": "^6.4.2",
    "@fortawesome/react-fontawesome": "^0.2.0",
    "@iconscout/react-unicons": "^2.0.2",
    "antd": "^6.4.3",
    "axios": "^1.13.2",
    "dayjs": "^1.11.19",
    "electron-log": "^5.4.3",
    "electron-pos-printer": "^1.3.7",
    "electron-updater": "^6.6.2",
    "http-proxy-middleware": "^2.0.6",
    "node-thermal-printer": "^4.4.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.11.0",
    "rollup-plugin-node-builtins": "^2.1.2",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "swiper": "^12.0.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^2.1.0",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@vitejs/plugin-react": "^5.1.2",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "prettier": "^3.7.4",
    "vite": "^7.3.0"
  }
}
